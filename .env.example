# Postgres connection string (Neon / Supabase / Vercel Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Site URL (sitemap, OG image, canonical)
NEXT_PUBLIC_SITE_URL="https://www.osmancancetlenbik.com"

# Admin paneli için (production'da güçlü değerler kullan)
# ADMIN_PASSWORD_HASH oluşturmak için: npx tsx scripts/hash-password.ts
# ADMIN_PASSWORD (plain) yalnız geriye dönük uyumluluk içindir — production'da hash kullanın.
ADMIN_PASSWORD_HASH=""
JWT_SECRET="32-karakter-veya-daha-uzun-rastgele-string"

# Contact form için (https://resend.com'dan al)
RESEND_API_KEY=""
CONTACT_TO_EMAIL="osmancancetlenbik@gmail.com"
